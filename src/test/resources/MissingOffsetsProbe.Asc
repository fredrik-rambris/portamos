' Missing-offset probe program
' Goal: exercise commands/functions listed in missing_offsets.txt
' This source is intentionally minimal and may not be meaningful at runtime.

screen open 0,320,200,16,lowres
cls 0

' --- Graphics: drawing state ---
pattern 1
pat$=pattern$
line style
set fill 0
fill style
set origin 10,20
origin
xo=x origin
yo=y origin
set clip 0,0 to 319,199
xc=x clip
yc=y clip

' --- Sprites / icons ---
sprite image 1,0
sprite coll 1
icon 1,16,16,1
icon off 1
icon image 1,0
icon coll 1

' --- Blitter ---
blit 0,0,0
blit wait
blit mode 0
blit fill 0,0,0
blit copy 0,0,0
blit test

' --- Hardware: copper, raster, interrupts, dma ---
set copper 0
copper wait 0
copper move 0,0
set raster 0
raster on
raster off
set int 0
int on
int off
set dma 0
dma on
dma off

' Keep variables alive so AMOS does not optimize them away in some tools
print pat$,xo,yo,xc,yc
end

