
' Screens
' 0 - Debug
' 3 - Palette colours
' 4 - UI 

' Globals
DEBUG=True
Dim PAL(32) : Rem Our palette
BPL=0 : Rem Number of bitplanes
CURCOL=1 : Rem Current selected colour
YPOS=45 : Rem Where on screen the editor is positioned 



P_SETUP
P_UI
P_LOAD_PALETTE
P_SHOW_PALETTE
P_SELECT_COLOUR[1]



Repeat 
   P_CHECK_PALETTE_CLICK
   D=Dialog(1)
   If D>0 and D<4
      P_RGB_SLIDER_CHANGE[D]
   Else If D=4
      Exit 
   Else If D>=5 and D<=9
      BPL=D-4
      P_DEBUG[Str$(BPL)]
      P_SHOW_PALETTE
   Else If D=10
      YDELTA=Y Screen(3,Y Mouse)
      Repeat 
         Wait Vbl 
         YPOS=Y Mouse-YDELTA
         Screen Display 3,,YPOS,,
         Screen Display 4,,YPOS+Screen Height(3)+1,,
      Until(Mouse Key and 1)=0
   End If 
   
   
   Wait Vbl 
   
Until Inkey$=Chr$(27)


Erase 16
Edit 
End 

Procedure P_RGB_SLIDER_CHANGE[D]
   Global PAL(),CURCOL,C
   
   R=15-Rdialog(1,1)
   G=15-Rdialog(1,2)
   B=15-Rdialog(1,3)
   
   C=(256*R)+(16*G)+B
   
   Screen 3
   PAL(CURCOL)=C
   Colour CURCOL,C
   Screen 4
End Proc

Procedure P_CHECK_PALETTE_CLICK
   ' Mouse Zone only checks zones on current screen 
   MCOL=Zone(3,X Screen(3,X Mouse),Y Screen(3,Y Mouse))-1
   If MCOL>=0 and(Mouse Key and 1)
      P_DEBUG[Str$(MCOL)]
      
      P_SELECT_COLOUR[MCOL]
      
      Repeat 
         Wait Vbl 
      Until Mouse Key=0
   End If 
End Proc

Procedure P_SELECT_COLOUR[C]
   Global CURCOL,PAL(),BPL
   
   RV=$F-((PAL(C) and $F00)/$100)
   GV=$F-((PAL(C) and $F0)/$10)
   BV=$F-(PAL(C) and $F)
   
   Trap Dialog Update 1,1,RV
   Trap Dialog Update 1,2,GV
   Trap Dialog Update 1,3,BV
   
   
   NUMCOL=2^BPL
   W=Screen Width/NUMCOL
   
   
   ' Screen 0 
   'Print "Bar",NUMCOL,CURCOL*W,0,CURCOL*W+W,Screen Height-1
   
   CURCOL=C
   
   
   P_SHOW_PALETTE
   
   'Ink CURCOL
   'Bar CURCOL*W,0 To CURCOL*W+W,Screen Height-1
   Screen 3
   Wait Vbl 
   If C=0 Then Ink NUMCOL-1 Else Ink 0
   Box C*W,0 To C*W+W,Screen Height-1
   
End Proc

Procedure P_SETUP
   Global YPOS,DEBUG
   
   ' Palette screen 
   Screen Open 3,320,16,32,Lowres : Flash Off : Curs Off : Paper 0 : Pen 1 : Cls 
   Reserve Zone 32
   
   ' UI screen
   Trap Load Resource$(0)+"AMOSPro_Default_Resource.Abk.bak"
   Resource Bank 16
   Resource Screen Open 4,640,70,0 : Curs Off : Paper 0 : Pen 1 : Cls 
   Screen Display 3,,YPOS,,
   Screen Display 4,,YPOS+Screen Height(3)+1,,
   
   If DEBUG
      Screen Open 0,640,150,2,Hires : Curs Off : Flash Off : Paper 0 : Pen 1 : Cls 
      Palette $0,$CCC
      Screen Display 0,,YPOS+Screen Height(3)+Screen Height(4)+2,,
      Screen To Back 0
   Else 
      Screen Close 0
   End If 
   
   
End Proc

Procedure P_UI

   ' Read Dialog program from text file 
   Open In 1,"PaletteEditor.ui"
   Set Input 10,-1
   While Eof(1)=0
      Line Input #1,LINE$

      ' Allow for comments beginning with #
      If Len(LINE$)>0 and Mid$(LINE$,0,1)<>"#"
         D$=D$+LINE$
      End If 
   Wend 
   Close 1
   Screen 4
   
   On Error Goto SHOERR
   Dialog Open 1,D$
   D=Dialog Run(1)
   
   Pop Proc
   SHOERR:
   Screen 0
   Screen Hide 3
   Screen Hide 4
   Print Mid$(D$,Edialog,80) : Wait Key : End 
End Proc

Procedure P_LOAD_PALETTE
   Global PAL(),BPL
   Screen 4
   For C=0 To 16
      PAL(C)=Colour(C)
   Next C
   If False
      PAL(0)=$0
      PAL(1)=$FFF
      PAL(2)=$F00
      PAL(3)=$FF0
      PAL(4)=$F0
      PAL(5)=$FF
      PAL(6)=$F
      PAL(7)=$F0F
      PAL(8)=$F88
      PAL(9)=$FF8
      PAL(10)=$8F8
      PAL(11)=$8FF
      PAL(12)=$88F
      PAL(13)=$F8F
      PAL(14)=$888
      PAL(15)=$CCC
   End If 
   BPL=3
   Dialog Update 1,4+BPL,1
End Proc

Procedure P_SHOW_PALETTE
   Global BPL,PAL()
   
   Screen 3
   
   
   If BPL=0
      Cls 
      Pop Proc
   End If 
   
   NUMCOL=2^BPL
   W=Screen Width/NUMCOL
   
   For P=0 To NUMCOL-1
      Colour P,PAL(P)
      Ink P
      Bar P*W,0 To P*W+W,Screen Height-1
      Set Zone P+1,P*W,0 To P*W+W,Screen Height-1
   Next P
End Proc

Procedure P_DEBUG[MSG$]
   Global DEBUG
   If DEBUG
      Screen 0
      Print MSG$
   End If 
End Proc
